{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taskbridge.local/schemas/actions.schema.json",
  "title": "TaskBridge Actions",
  "type": "object",
  "required": ["schema", "actions"],
  "properties": {
    "schema": {
      "const": "taskbridge.actions.v1"
    },
    "source": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string"
          },
          "task_id": {
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "due_date": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "requires_confirmation": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
